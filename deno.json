{
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "files": {
      "include": ["js/**/*.js", "tests/**/*.ts"]
    }
  },
  "test": {
    "include": ["tests/**/*.ts"]
  },
  "tasks": {
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-read"
  }
}
